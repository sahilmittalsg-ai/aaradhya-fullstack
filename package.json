{
  "name": "spiritual-commerce-mern",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace server\" \"npm run dev --workspace client\"",
    "dev:client": "npm run dev --workspace client",
    "dev:admin": "npm run dev --workspace admin-side",
    "build": "npm run build --workspace server && npm run build --workspace client",
    "build:admin": "npm run build --workspace admin-side",
    "seed": "npm run seed --workspace server"
  },
  "workspaces": [
    "client",
    "admin-side",
    "server"
  ],
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
